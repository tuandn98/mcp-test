============================================
# TronSave Environment Variables Reference
============================================
# This file is for reference only and is NOT read by the server.
# All variables must be injected via the env field in your MCP JSON config:
#
#   .mcp.json
#   settings.json (Claude Desktop / Claude Code)
#
# Example minimum config (.mcp.json):
# {
#   "mcpServers": {
#     "tronsave": {
#       "command": "node",
#       "args": ["dist/index.js"],
#       "env": {
#         "NETWORK": "mainnet",
#         "TRONSAVE_API_KEY": "your-key"
#       }
#     }
#   }
# }

# ============================================
# Runtime Mode
# ============================================
# NETWORK controls which TronSave API base URL is used:
# - "mainnet": https://api.tronsave.io
# - anything else (or omitted): https://api-dev.tronsave.io
NETWORK=mainnet

# ============================================
# TronSave API Key
# ============================================
# Used as the `apikey` header to authenticate requests.
# If you do not have a key yet, you can leave it empty (some environments may allow anonymous access).
TRONSAVE_API_KEY=

# ============================================
# Optional MCP Event Logging (MongoDB)
# ============================================
# When set, the server writes MCP observability events into:
# - mcp_events (one row per MCP HTTP request)
# - mcp_buy_events (buy-funnel row with order reference when available)
# If omitted, MCP event logging is skipped silently.
MONGODB_URI=
MONGODB_DB_NAME=tronsave_mcp

